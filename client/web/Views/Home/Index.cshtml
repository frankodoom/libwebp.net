@model web.Models.ConvertViewModel
@{
    ViewData["Title"] = "LibWebp.Net — WebP Encoder (libwebp 1.5.0)";
}

<div class="text-center">
    <img src="~/images/webplogo.png" style="margin-top:30px" alt="LibWebp.Net logo" />
    <p class="mt-2">Upload an image and convert it to Google's WebP format with full control over every option.</p>
</div>

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            @* ═══ Quick Convert (Middleware-powered) ══════════════════ *@
            <div class="card mb-4 border-primary">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="fas fa-bolt me-1"></i> Quick Convert — Middleware
                    <span class="badge bg-light text-primary ms-2">NEW</span>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-2">
                        The <code>WebpUploadMiddleware</code> automatically converts every uploaded image
                        to WebP <em>before</em> the controller even sees it. Just pick a file and click convert.
                    </p>
                    <form asp-controller="Home" asp-action="QuickConvert" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="d-flex align-items-center gap-2">
                            <input type="file" name="file" class="form-control form-control-lg"
                                   accept="image/jpeg,image/png,image/gif,image/bmp,image/tiff" />
                            <button type="submit" class="btn btn-lg btn-primary">
                                <i class="fas fa-magic"></i> Convert
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <hr class="my-4" />
            <h5 class="text-center text-muted mb-3">
                <i class="fas fa-sliders-h me-1"></i> Advanced — Manual Conversion with Full Options
            </h5>

            <form asp-controller="Home" asp-action="Convert" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                @* ── File picker + Convert button ─────────────────── *@
                <div class="card mb-3">
                    <div class="card-body d-flex align-items-center gap-2">
                        <input asp-for="File" class="form-control form-control-lg" id="fileInput" />
                        <button type="button" class="btn btn-lg btn-info" data-bs-toggle="collapse"
                                data-bs-target="#advancedOptions" id="configureBtn" style="display:none">
                            <i class="fas fa-wrench"></i>
                        </button>
                        <button type="submit" class="btn btn-lg btn-success" id="convertBtn">
                            <i id="cog" class="fas fa-cog"></i> Convert
                        </button>
                    </div>
                    <span asp-validation-for="File" class="text-danger px-3 pb-2"></span>
                </div>

                @* ── Advanced Options (collapsed) ─────────────────── *@
                <div class="collapse" id="advancedOptions">

                    @* ── Basic ────────────────────────────────────── *@
                    <div class="card mb-3">
                        <div class="card-header fw-bold"><i class="fas fa-sliders-h me-1"></i> Basic</div>
                        <div class="card-body row g-3">
                            <div class="col-md-3">
                                <label asp-for="Preset" class="form-label">Preset</label>
                                <select asp-for="Preset" class="form-select">
                                    <option value="">— none —</option>
                                    <option value="default">Default</option>
                                    <option value="photo">Photo</option>
                                    <option value="picture">Picture</option>
                                    <option value="drawing">Drawing</option>
                                    <option value="icon">Icon</option>
                                    <option value="text">Text</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="QualityFactor" class="form-label">Quality (0–100)</label>
                                <input asp-for="QualityFactor" class="form-control" type="number" min="0" max="100" step="0.1" placeholder="75" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="CompressionMethod" class="form-label">Method (0–6)</label>
                                <input asp-for="CompressionMethod" class="form-control" type="number" min="0" max="6" placeholder="4" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="Pass" class="form-label">Pass (1–10)</label>
                                <input asp-for="Pass" class="form-control" type="number" min="1" max="10" placeholder="1" />
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-4">
                                    <input asp-for="Lossless" class="form-check-input" type="checkbox" />
                                    <label asp-for="Lossless" class="form-check-label">Lossless</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="LosslessPreset" class="form-label">Lossless Preset (0–9)</label>
                                <input asp-for="LosslessPreset" class="form-control" type="number" min="0" max="9" placeholder="" />
                            </div>
                        </div>
                    </div>

                    @* ── Quality & Size Control ───────────────────── *@
                    <div class="card mb-3">
                        <div class="card-header fw-bold"><i class="fas fa-compress-arrows-alt me-1"></i> Quality &amp; Size Control</div>
                        <div class="card-body row g-3">
                            <div class="col-md-3">
                                <label asp-for="TargetSize" class="form-label">Target Size (bytes)</label>
                                <input asp-for="TargetSize" class="form-control" type="number" min="0" placeholder="" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="TargetPSNR" class="form-label">Target PSNR (dB)</label>
                                <input asp-for="TargetPSNR" class="form-control" type="number" step="0.1" min="0" placeholder="" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="NearLossless" class="form-label">Near-Lossless (0–100)</label>
                                <input asp-for="NearLossless" class="form-control" type="number" min="0" max="100" placeholder="100 = off" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="Hint" class="form-label">Hint</label>
                                <select asp-for="Hint" class="form-select">
                                    <option value="">— none —</option>
                                    <option value="photo">Photo</option>
                                    <option value="picture">Picture</option>
                                    <option value="graph">Graph</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    @* ── Filter & Sharpness ───────────────────────── *@
                    <div class="card mb-3">
                        <div class="card-header fw-bold"><i class="fas fa-adjust me-1"></i> Filter &amp; Sharpness</div>
                        <div class="card-body row g-3">
                            <div class="col-md-3">
                                <label asp-for="Filter" class="form-label">Filter (0–100)</label>
                                <input asp-for="Filter" class="form-control" type="number" min="0" max="100" placeholder="" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="Sharpness" class="form-label">Sharpness (0–7)</label>
                                <input asp-for="Sharpness" class="form-control" type="number" min="0" max="7" placeholder="0" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="FilterType" class="form-label">Filter Type</label>
                                <select asp-for="FilterType" class="form-select">
                                    <option value="">— default —</option>
                                    <option value="strong">Strong</option>
                                    <option value="nostrong">Simple (no strong)</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="SpatialNoiseShaping" class="form-label">SNS (0–100)</label>
                                <input asp-for="SpatialNoiseShaping" class="form-control" type="number" min="0" max="100" placeholder="50" />
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-4">
                                    <input asp-for="SharpYuv" class="form-check-input" type="checkbox" />
                                    <label asp-for="SharpYuv" class="form-check-label">Sharp YUV</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* ── Segments & Partitions ────────────────────── *@
                    <div class="card mb-3">
                        <div class="card-header fw-bold"><i class="fas fa-th me-1"></i> Segments &amp; Partitions</div>
                        <div class="card-body row g-3">
                            <div class="col-md-4">
                                <label asp-for="NumberOfSegments" class="form-label">Segments (1–4)</label>
                                <input asp-for="NumberOfSegments" class="form-control" type="number" min="1" max="4" placeholder="4" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="PartitionLimit" class="form-label">Partition Limit (0–100)</label>
                                <input asp-for="PartitionLimit" class="form-control" type="number" min="0" max="100" placeholder="" />
                            </div>
                        </div>
                    </div>

                    @* ── Alpha / Transparency ─────────────────────── *@
                    <div class="card mb-3">
                        <div class="card-header fw-bold"><i class="fas fa-eye me-1"></i> Alpha / Transparency</div>
                        <div class="card-body row g-3">
                            <div class="col-md-3">
                                <label asp-for="AlphaQ" class="form-label">Alpha Quality (0–100)</label>
                                <input asp-for="AlphaQ" class="form-control" type="number" min="0" max="100" placeholder="" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="AlphaMethod" class="form-label">Alpha Method (0–1)</label>
                                <input asp-for="AlphaMethod" class="form-control" type="number" min="0" max="1" placeholder="1" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="AlphaFilter" class="form-label">Alpha Filter</label>
                                <select asp-for="AlphaFilter" class="form-select">
                                    <option value="">— default —</option>
                                    <option value="none">None</option>
                                    <option value="fast">Fast</option>
                                    <option value="best">Best</option>
                                </select>
                            </div>
                            <div class="col-md-3 d-flex gap-3 align-items-end">
                                <div class="form-check">
                                    <input asp-for="NoAlpha" class="form-check-input" type="checkbox" />
                                    <label asp-for="NoAlpha" class="form-check-label">No Alpha</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="Exact" class="form-check-input" type="checkbox" />
                                    <label asp-for="Exact" class="form-check-label">Exact</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* ── Image Transform ──────────────────────────── *@
                    <div class="card mb-3">
                        <div class="card-header fw-bold"><i class="fas fa-crop-alt me-1"></i> Image Transform</div>
                        <div class="card-body row g-3">
                            <div class="col-12"><strong>Crop</strong> <small class="text-muted">(leave empty to skip)</small></div>
                            <div class="col-md-3">
                                <label asp-for="CropX" class="form-label">X</label>
                                <input asp-for="CropX" class="form-control" type="number" min="0" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="CropY" class="form-label">Y</label>
                                <input asp-for="CropY" class="form-control" type="number" min="0" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="CropW" class="form-label">Width</label>
                                <input asp-for="CropW" class="form-control" type="number" min="1" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="CropH" class="form-label">Height</label>
                                <input asp-for="CropH" class="form-control" type="number" min="1" />
                            </div>

                            <div class="col-12 mt-3"><strong>Resize</strong> <small class="text-muted">(0 for either dimension to keep aspect ratio)</small></div>
                            <div class="col-md-3">
                                <label asp-for="ResizeW" class="form-label">Width</label>
                                <input asp-for="ResizeW" class="form-control" type="number" min="0" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="ResizeH" class="form-label">Height</label>
                                <input asp-for="ResizeH" class="form-control" type="number" min="0" />
                            </div>
                        </div>
                    </div>

                    @* ── Performance & Metadata ───────────────────── *@
                    <div class="card mb-3">
                        <div class="card-header fw-bold"><i class="fas fa-tachometer-alt me-1"></i> Performance &amp; Metadata</div>
                        <div class="card-body row g-3">
                            <div class="col-md-3">
                                <div class="form-check mt-2">
                                    <input asp-for="MultiThreading" class="form-check-input" type="checkbox" />
                                    <label asp-for="MultiThreading" class="form-check-label">Multi-Threading</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-2">
                                    <input asp-for="LowMemory" class="form-check-input" type="checkbox" />
                                    <label asp-for="LowMemory" class="form-check-label">Low Memory</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Metadata" class="form-label">Metadata</label>
                                <select asp-for="Metadata" class="form-select">
                                    <option value="">none (default)</option>
                                    <option value="all">All</option>
                                    <option value="exif">EXIF</option>
                                    <option value="icc">ICC</option>
                                    <option value="xmp">XMP</option>
                                    <option value="exif,icc">EXIF + ICC</option>
                                    <option value="exif,icc,xmp">EXIF + ICC + XMP</option>
                                </select>
                            </div>
                        </div>
                    </div>

                </div><!-- /advancedOptions -->
            </form>

        </div>
    </div>
</div>

@section Scripts {
<script>
    var fileInput = document.getElementById("fileInput");
    var configureBtn = document.getElementById("configureBtn");
    var convertBtn = document.getElementById("convertBtn");
    var cog = document.getElementById("cog");

    fileInput.addEventListener("change", function () {
        if (fileInput.files.length > 0) {
            configureBtn.style.display = "";
        }
    });

    convertBtn.addEventListener("click", function () {
        cog.classList.add("fa-spin");
    });
</script>
}
